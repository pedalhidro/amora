#------------------------------------------------------------------------------
# exiftool_ph.config — namespace XMP "ph" do Pedal Hidrográfico
#
# Registra o namespace https://pedalhidrografi.co/vocab/1.0/ para que o
# exiftool possa ler e gravar tags da ontologia Pedal Hidrográfico dentro de
# fotos (JPEG/HEIC) e vídeos (MOV).
#
# Uso:
#   exiftool -config exiftool_ph.config -XMP-ph:RideCode="PH 88" foto.heic
#   exiftool -config exiftool_ph.config -XMP-ph:all foto.heic        # ler
#
# Tags:
#   XMP-ph:CapturedDuring  IRI do pedal (ph:capturedDuring da ontologia)
#   XMP-ph:RideCode        código preferido do pedal, ex. "PH 88"
#   XMP-ph:RideCodes       lista de todos os códigos, ex. "eH 1", "PH 1"
#   XMP-ph:RideName        nome/título do pedal
#   XMP-ph:RideDate        data do pedal (AAAA-MM-DD)
#   XMP-ph:Collective      coletivo ("Pedal Hidrográfico")
#------------------------------------------------------------------------------

%Image::ExifTool::UserDefined::ph = (
    GROUPS    => { 0 => 'XMP', 1 => 'XMP-ph', 2 => 'Other' },
    NAMESPACE => { 'ph' => 'https://pedalhidrografi.co/vocab/1.0/' },
    WRITABLE  => 'string',
    CapturedDuring => { },
    RideCode       => { },
    RideCodes      => { List => 'Bag' },
    RideName       => { },
    RideDate       => { Groups => { 2 => 'Time' } },
    Collective     => { },
);

%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::Main' => {
        ph => {
            SubDirectory => {
                TagTable => 'Image::ExifTool::UserDefined::ph',
            },
        },
    },
);

1;  #  um arquivo de config do exiftool precisa terminar com valor verdadeiro
