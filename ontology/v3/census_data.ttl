# Data Graph

### Orgs

phd:pedal_hidrografico a schema:SportsOrganization ;
    schema:name "Pedal Hidrográfico" ;
    schema:sport "Cycling" ;
    schema:url <https://pedalhidrografi.co/> ;
    schema:sameAs <https://www.instagram.com/pedalhidrografico/> ;
    schema:areaServed [ a schema:City ; schema:name "São Paulo" ] ;
    schema:description "Coletivo de ciclismo urbano focado em rios e córregos de São Paulo."@pt .

phd:bicipassarinhada a schema:SportsOrganization ;
    schema:name "Bicipassarinhada" ;
    schema:sport "Cycling" .

### Rides 

phd:pha1_narrative a censo:Narrative ;
    prov.a

phd:ph1 a censo:BicycleTour ;
    censo:title "Água Preta e Tiburtino" ;
    censo:hasEdition censo:PH1, censo:BP1 ;
    censo:scheduledStartTime "2024-09-09 20:00" ;
    censo:narrative ph1_narrative .

censo:PH a censo:Series ;
    censo:inSeries censo:PH ;
    censo:editionNumber 1 .

censo:BP1 a censo:Series ;
    censo:inSeries censo:PH ;
    censo:editionNumber 1 .


