# Pedal Hidrográfico — Censo Hidrográfico microdata, expressed as RDF.
# Generated from the source CSV; predicate vocabulary matches the Tour SPARQL query.
@prefix ph:     <https://pedalhidrografico.example/ont#> .
@prefix phd:    <https://pedalhidrografico.example/id/> .
@prefix schema: <https://schema.org/> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# ---- vocabulary (minted ph: terms; reuse schema: where it fits) ----
ph:Tour a owl:Class ; rdfs:label "Pedal Hidrográfico tour" .
ph:Media a owl:Class ; rdfs:label "Collected media item" .
ph:Attendance a owl:Class ; rdfs:label "Attendance record (person at a tour)" .
ph:date a owl:DatatypeProperty ; rdfs:label "date" .
ph:uuid a owl:DatatypeProperty ; rdfs:label "global edition id (eH)" .
ph:edition a owl:DatatypeProperty ; rdfs:label "Pedal Hidrográfico number (PH)" .
ph:hadPublicAnnouncement a owl:DatatypeProperty ; rdfs:label "had public announcement" .
ph:hadBikeLift a owl:DatatypeProperty ; rdfs:label "had bonde/bike-lift" .
ph:rained a owl:DatatypeProperty ; rdfs:label "rained" .
ph:routedBy a owl:ObjectProperty ; rdfs:label "routed by" .
ph:writtenBy a owl:ObjectProperty ; rdfs:label "written by" .
ph:artBy a owl:ObjectProperty ; rdfs:label "art by" .
ph:instagramPost a owl:DatatypeProperty ; rdfs:label "Instagram post URL" .
ph:plannedRoute a owl:ObjectProperty ; rdfs:label "planned route" .
ph:actualActivity a owl:ObjectProperty ; rdfs:label "actual activity" .
ph:plannedDeparture a owl:DatatypeProperty ; rdfs:label "planned departure" .
ph:observedDeparture a owl:DatatypeProperty ; rdfs:label "observed departure" .
ph:observedArrival a owl:DatatypeProperty ; rdfs:label "observed arrival" .
ph:observedHeadcount a owl:DatatypeProperty ; rdfs:label "observed headcount" .
ph:observedNewcomerCount a owl:DatatypeProperty ; rdfs:label "observed newcomer count" .
ph:observedActivityCount a owl:DatatypeProperty ; rdfs:label "observed strava-activity count" .
ph:energyKJ a owl:DatatypeProperty ; rdfs:label "energy expenditure (kJ)" .
ph:attendance a owl:ObjectProperty ; rdfs:label "attendance" .
ph:person a owl:ObjectProperty ; rdfs:label "person" .
ph:newcomer a owl:DatatypeProperty ; rdfs:label "is newcomer" .
ph:stravaActivity a owl:ObjectProperty ; rdfs:label "strava activity" .
ph:depictsTour a owl:ObjectProperty ; rdfs:label "depicts tour" .
ph:category a owl:DatatypeProperty ; rdfs:label "category" .
ph:mediaCount a owl:DatatypeProperty ; rdfs:label "collected media count" .
ph:photosCollected a owl:DatatypeProperty ; rdfs:label "photos were collected" .
ph:attendanceListed a owl:DatatypeProperty ; rdfs:label "attendance individually listed" .

# ── edition 1 ──
phd:tour-1
    a ph:Tour ;
