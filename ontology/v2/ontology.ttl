@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ph: <https://pedalhidrografi.co/censo/1.0/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema:  <https://schema.org/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .


ph: a owl:Ontology ;    
    dcterms:title "Pedal Hidrográfico Census Vocabulary"@en ,
                  "Vocabulário do Censo do Pedal Hidrográfico"@pt ;
    dcterms:description
        "Vocabulary for the rides of the Pedal Hidrográfico cycling collective: tours, planned and actual routes, narrative, attendance, georeferenced media and social posts."@en ;
    owl:versionInfo "1.1" ;
    dcterms:creator "Pedal Hidrográfico" ;
    dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> .


ph:Tour a owl:Class ;
    rdfs:subClassOf schema:SportsEvent , prov:Activity ;
    rdfs:label "Tour"@en , "Pedal"@pt ;
    rdfs:comment
        "A single Pedal Hidrográfico ride as a social event. The hub entity: it ties together a planned route, an actual (recorded) route, a narrative, the gathering details, attendance and media. Modelled both as a schema:SportsEvent (it is an event) and a prov:Activity (it consumes a plan and produces a recording)."@en .


ph:hasPlannedRoute a owl:ObjectProperty ;
    rdfs:domain ph:Tour ;
    rdfs:range  ph:PlannedRoute ;
    rdfs:label  "has planned route"@en , "tem rota planejada"@pt ;
    rdfs:comment
        "Associates a Tour with the route that was planned for it (the intended path, before the ride)."@en .


ph:hasPhoto a owl:ObjectProperty ;
    rdfs:domain ph:Tour ;
    rdfs:range  ph:Photo ;
    rdfs:label  "has photo"@en , "tem foto"@pt ;
    rdfs:comment
        "Associates a Tour with a photo taken during it."@en .


ph:hasInstagramPost a owl:ObjectProperty ;
    rdfs:domain ph:Tour ;
    rdfs:range  ph:InstagramPost ;
    rdfs:label  "has Instagram post"@en , "tem post no Instagram"@pt ;
    rdfs:comment
        "Associates a Tour with an Instagram post that documents or announces it."@en .


# ---------------------------------------------------------------------------
# Shared properties
# ---------------------------------------------------------------------------

ph:hasAuthor a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:creator ;
    rdfs:range  schema:Person ;
    rdfs:label  "has author"@en , "tem autor"@pt ;
    rdfs:comment
        "Identifies a person responsible for creating the subject resource. Multi-valued — declare once per author."@en .


# ---------------------------------------------------------------------------
# InstagramPost and friends
# ---------------------------------------------------------------------------

ph:InstagramPost a owl:Class ;
    rdfs:subClassOf schema:SocialMediaPosting ;
    rdfs:label "Instagram post"@en , "Post no Instagram"@pt ;
    rdfs:comment
        "An Instagram post that documents or announces a Tour. Carries a narrative, a URL to the live post, and observed engagement stats."@en .

ph:hasNarrativeText a owl:ObjectProperty ;
    rdfs:domain ph:InstagramPost ;
    rdfs:range  ph:NarrativeText ;
    rdfs:label  "has narrative text"@en , "tem texto narrativo"@pt ;
    rdfs:comment
        "Associates an Instagram post with its narrative-text body."@en .

ph:hasInstagramPostStats a owl:ObjectProperty ;
    rdfs:domain ph:InstagramPost ;
    rdfs:range  ph:InstagramPostStats ;
    rdfs:label  "has Instagram post stats"@en , "tem estatísticas do post"@pt ;
    rdfs:comment
        "Associates an Instagram post with an engagement-stats snapshot. May repeat across observation times."@en .

# (Use schema:url on InstagramPost for the live-post URL — no custom property minted.)


ph:NarrativeText a owl:Class ;
    rdfs:label "Narrative text"@en , "Texto narrativo"@pt ;
    rdfs:comment
        "An authored prose fragment — a caption, story, or description — attached to a resource such as an Instagram post."@en .

ph:content a owl:DatatypeProperty ;
    rdfs:subPropertyOf schema:text ;
    rdfs:domain ph:NarrativeText ;
    rdfs:range  xsd:string ;
    rdfs:label  "content"@en , "conteúdo"@pt ;
    rdfs:comment
        "The textual body of the narrative."@en .

# (ph:hasAuthor reused on NarrativeText — no new property minted.)


ph:InstagramPostStats a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Instagram post stats"@en , "Estatísticas do post"@pt ;
    rdfs:comment
        "A point-in-time snapshot of engagement metrics for an Instagram post."@en .

ph:likes a owl:DatatypeProperty ;
    rdfs:domain ph:InstagramPostStats ;
    rdfs:range  xsd:integer ;
    rdfs:label  "likes"@en , "curtidas"@pt ;
    rdfs:comment
        "Number of likes at observation time."@en .

ph:messageShares a owl:DatatypeProperty ;
    rdfs:domain ph:InstagramPostStats ;
    rdfs:range  xsd:integer ;
    rdfs:label  "message shares"@en , "compartilhamentos por mensagem"@pt ;
    rdfs:comment
        "Number of private shares (via DM) at observation time."@en .

ph:reposts a owl:DatatypeProperty ;
    rdfs:domain ph:InstagramPostStats ;
    rdfs:range  xsd:integer ;
    rdfs:label  "reposts"@en , "republicações"@pt ;
    rdfs:comment
        "Number of public reposts at observation time."@en .

# (Use prov:generatedAtTime on InstagramPostStats for observedAt — no custom property minted.)


# ---------------------------------------------------------------------------
# Photo
# ---------------------------------------------------------------------------

ph:Photo a owl:Class ;
    rdfs:subClassOf schema:Photograph ;
    rdfs:label "Photo"@en , "Foto"@pt ;
    rdfs:comment
        "A georeferenced photograph taken during or associated with a Tour."@en .

ph:hasLocation a owl:ObjectProperty ;
    rdfs:domain ph:Photo ;
    rdfs:range  schema:GeoCoordinates ;
    rdfs:label  "has location"@en , "tem localização"@pt ;
    rdfs:comment
        "Geographic coordinates where the photo was captured."@en .

ph:fieldOfView a owl:DatatypeProperty ;
    rdfs:domain ph:Photo ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "field of view"@en , "campo de visão"@pt ;
    rdfs:comment
        "Horizontal angular field of view at capture, in degrees (0–180)."@en .

# (ph:hasAuthor reused on Photo; dcterms:license carries the license — no custom properties minted.)


# ---------------------------------------------------------------------------
# PlannedRoute
# ---------------------------------------------------------------------------

ph:PlannedRoute a owl:Class ;
    rdfs:subClassOf prov:Plan , schema:CreativeWork ;
    rdfs:label "Planned route"@en , "Rota planejada"@pt ;
    rdfs:comment
        "The intended path for a Tour, authored before the ride. Typically references an external trace (e.g. on RideWithGPS) via schema:url."@en .

ph:hasPlannedRouteStats a owl:ObjectProperty ;
    rdfs:domain ph:PlannedRoute ;
    rdfs:range  ph:PlannedRouteStats ;
    rdfs:label  "has planned-route stats"@en , "tem estatísticas da rota planejada"@pt ;
    rdfs:comment
        "Associates a planned route with its computed metrics (distance, ascent, energy)."@en .

# (Use schema:url on PlannedRoute for the source URL; ph:hasAuthor for authorship — no custom properties minted.)


ph:PlannedRouteStats a owl:Class ;
    rdfs:label "Planned-route stats"@en , "Estatísticas da rota planejada"@pt ;
    rdfs:comment
        "Computed metrics for a planned route."@en .

ph:distanceKm a owl:DatatypeProperty ;
    rdfs:domain ph:PlannedRouteStats ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "distance (km)"@en , "distância (km)"@pt ;
    rdfs:comment
        "Total route length in kilometres."@en .

ph:ascentMeters a owl:DatatypeProperty ;
    rdfs:domain ph:PlannedRouteStats ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "ascent (m)"@en , "subida (m)"@pt ;
    rdfs:comment
        "Cumulative positive elevation gain in metres."@en .

ph:estimatedMovementEnergyKj a owl:DatatypeProperty ;
    rdfs:domain ph:PlannedRouteStats ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "estimated movement energy (kJ)"@en , "energia de movimento estimada (kJ)"@pt ;
    rdfs:comment
        "Estimated mechanical energy required to traverse the route, in kilojoules."@en .



