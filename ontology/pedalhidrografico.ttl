# Pedal Hidrográfico — Vocabulário / Vocabulary
#
# Ontologia leve para descrever os passeios ("pedais") do coletivo
# Pedal Hidrográfico: rotas planejadas vs. realizadas, narrativa, presença,
# mídia georreferenciada e publicações em redes sociais.
#
# Princípio de design: reutilizar vocabulários consolidados (schema.org,
# PROV-O, QUDT, GeoSPARQL, Dublin Core) para o que é genérico; cunhar termos
# `ph:` apenas para o que é específico do Pedal Hidrográfico.
#
# Namespace: https://pedalhidrografi.co/vocab/1.0/
# Versão: 1.1

@prefix ph:      <https://pedalhidrografi.co/vocab/1.0/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema:  <https://schema.org/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix geo:     <http://www.opengis.net/ont/geosparql#> .

# ─────────────────────────────────────────────────────────────────────────
# Ontology header
# ─────────────────────────────────────────────────────────────────────────

ph: a owl:Ontology ;
    dcterms:title "Pedal Hidrográfico Vocabulary"@en ,
                  "Vocabulário Pedal Hidrográfico"@pt ;
    dcterms:description
        "Vocabulary for the rides of the Pedal Hidrográfico cycling collective: tours, planned and actual routes, narrative, attendance, georeferenced media and social posts."@en ;
    owl:versionInfo "1.1" ;
    dcterms:creator "Pedal Hidrográfico" ;
    dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> .

# ═════════════════════════════════════════════════════════════════════════
# CLASSES
# ═════════════════════════════════════════════════════════════════════════

# ─── Tour — the hub entity ───────────────────────────────────────────────

ph:Tour a owl:Class ;
    rdfs:subClassOf schema:SportsEvent , prov:Activity ;
    rdfs:label "Tour"@en , "Pedal"@pt ;
    rdfs:comment
        "A single Pedal Hidrográfico ride as a social event. The hub entity: it ties together a planned route, an actual (recorded) route, a narrative, the gathering details, attendance and media. Modelled both as a schema:SportsEvent (it is an event) and a prov:Activity (it consumes a plan and produces a recording)."@en .

# ─── Routes ──────────────────────────────────────────────────────────────

ph:Route a owl:Class ;
    rdfs:label "Route"@en , "Rota"@pt ;
    rdfs:comment
        "Abstract cyclable path with a geometry. Not instantiated directly — use ph:PlannedRoute or ph:ActualRoute."@en .

ph:PlannedRoute a owl:Class ;
    rdfs:subClassOf ph:Route , prov:Plan ;
    rdfs:label "Planned route"@en , "Rota planejada"@pt ;
    rdfs:comment
        "The intended path, drawn before the ride. Prescriptive. A single planned route may be reused by several tours (the same loop ridden more than once)."@en .

ph:ActualRoute a owl:Class ;
    rdfs:subClassOf ph:Route ;
    rdfs:label "Actual route"@en , "Rota realizada"@pt ;
    rdfs:comment
        "The path actually ridden, as recorded by GPS. Descriptive. Generated by exactly one tour (1:1). Linked back to its plan via ph:executionOf."@en .

# ─── Ride metrics ────────────────────────────────────────────────────────

ph:RideMetrics a owl:Class ;
    rdfs:label "Ride metrics"@en , "Métricas do pedal"@pt ;
    rdfs:comment
        "A bundle of quantitative facts about a route — distance, ascent, descent, energy, duration. Attached to a ph:Route (not the tour) so that planned and actual figures can be compared. Quantities follow the QUDT pattern."@en .

# ─── Gathering ───────────────────────────────────────────────────────────

ph:Gathering a owl:Class ;
    rdfs:label "Gathering"@en , "Ponto de encontro"@pt ;
    rdfs:comment
        "Where and when participants meet before a tour departs. Reuses schema:Place for the location. Note: schema.org already distinguishes schema:doorTime (arrival/gathering time) from schema:startTime (departure); ph:gatheringTime is the doorTime analogue."@en .

# ─── Narrative ───────────────────────────────────────────────────────────

ph:TourNarrative a owl:Class ;
    rdfs:subClassOf schema:CreativeWork ;
    rdfs:label "Tour narrative"@en , "Narrativa do pedal"@pt ;
    rdfs:comment
        "The authored prose account of a tour — the human-written story. It is the SOURCE: social-media posts are derived FROM the narrative, never the other way round. (Scraping captions back out of Instagram is an implementation workaround, not the real provenance.)"@en .

# ─── Media ───────────────────────────────────────────────────────────────

ph:Media a owl:Class ;
    rdfs:subClassOf schema:MediaObject ;
    rdfs:label "Media"@en , "Mídia"@pt ;
    rdfs:comment
        "Abstract image or video asset. Geotagging is an intrinsic property (ph:capturedAt), not a subclass — 'georeferenced media' is simply Media that has a ph:capturedAt value."@en .

ph:Image a owl:Class ;
    rdfs:subClassOf ph:Media , schema:ImageObject ;
    rdfs:label "Image"@en , "Imagem"@pt ;
    rdfs:comment "A still photo (JPEG, HEIC, …)."@en .

ph:Video a owl:Class ;
    rdfs:subClassOf ph:Media , schema:VideoObject ;
    rdfs:label "Video"@en , "Vídeo"@pt ;
    rdfs:comment "A video clip (MOV, MP4, …)."@en .

# ─── Social posts ────────────────────────────────────────────────────────

ph:InstagramPost a owl:Class ;
    rdfs:subClassOf schema:SocialMediaPosting ;
    rdfs:label "Instagram post"@en , "Post no Instagram"@pt ;
    rdfs:comment
        "A permanent Instagram feed post. Derived from a ph:TourNarrative (use ph:derivedFromNarrative / prov:wasDerivedFrom)."@en .

ph:InstagramStory a owl:Class ;
    rdfs:subClassOf schema:SocialMediaPosting ;
    rdfs:label "Instagram story"@en , "Story no Instagram"@pt ;
    rdfs:comment
        "An ephemeral Instagram story. Derived from a piece of ph:Media (use ph:derivedFromMedia / prov:wasDerivedFrom)."@en .

# ─── People & attendance ─────────────────────────────────────────────────

ph:Person a owl:Class ;
    rdfs:subClassOf schema:Person ;
    rdfs:label "Person"@en , "Pessoa"@pt ;
    rdfs:comment "A participant. Carries the Instagram handle via ph:instagramHandle."@en .

ph:Attendance a owl:Class ;
    rdfs:label "Attendance"@en , "Presença"@pt ;
    rdfs:comment
        "A reified relationship between a person and a tour, so that a role can be attached. One ph:Attendance node per (person, tour) pair."@en .

ph:AttendanceRole a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Attendance role"@en , "Papel na presença"@pt ;
    rdfs:comment "Controlled vocabulary for the role a person played on a tour."@en .

# ─── Numbering schemes ───────────────────────────────────────────────────

ph:Series a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Ride series"@en , "Série de pedais"@pt ;
    rdfs:comment
        "A numbering scheme for tours. Pedal Hidrográfico runs several parallel series (eH, PH, BT, BP, S); each tour belongs to a series and carries an edition number within it."@en .

ph:SeriesEntry a owl:Class ;
    rdfs:label "Series entry"@en , "Entrada de série"@pt ;
    rdfs:comment
        "A tour's membership in one numbering series: pairs a ph:Series with the edition number the tour holds in it. A tour has one ph:SeriesEntry per series it is numbered in (e.g. eH 1 and PH 1 are two entries of the same tour)."@en .

# ─── Map layers ──────────────────────────────────────────────────────────

ph:MapLayer a owl:Class ;
    rdfs:label "Map layer"@en , "Camada do mapa"@pt ;
    rdfs:comment
        "A web tile layer the app draws as cartographic backdrop, under the routes and media. Abstract — use ph:BasemapLayer or ph:OverlayLayer."@en .

ph:BasemapLayer a owl:Class ;
    rdfs:subClassOf ph:MapLayer ;
    rdfs:label "Basemap layer"@en , "Camada base"@pt ;
    rdfs:comment
        "An opaque background layer; exactly one is active at a time (the app selects it with a radio button)."@en .

ph:OverlayLayer a owl:Class ;
    rdfs:subClassOf ph:MapLayer ;
    rdfs:label "Overlay layer"@en , "Camada de sobreposição"@pt ;
    rdfs:comment
        "A semi-transparent layer drawn over the basemap; any number may be visible at once, each with its own opacity."@en .

# ═════════════════════════════════════════════════════════════════════════
# OBJECT PROPERTIES
# ═════════════════════════════════════════════════════════════════════════

# ─── Tour structure ──────────────────────────────────────────────────────

ph:hasPlannedRoute a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:used ;
    rdfs:domain ph:Tour ;
    rdfs:range ph:PlannedRoute ;
    rdfs:label "has planned route"@en , "tem rota planejada"@pt .

ph:hasActualRoute a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:subPropertyOf prov:generated ;
    rdfs:domain ph:Tour ;
    rdfs:range ph:ActualRoute ;
    rdfs:label "has actual route"@en , "tem rota realizada"@pt .

ph:hasNarrative a owl:ObjectProperty ;
    rdfs:domain ph:Tour ;
    rdfs:range ph:TourNarrative ;
    rdfs:label "has narrative"@en , "tem narrativa"@pt .

ph:hasGathering a owl:ObjectProperty ;
    rdfs:domain ph:Tour ;
    rdfs:range ph:Gathering ;
    rdfs:label "has gathering"@en , "tem ponto de encontro"@pt .

ph:hasAttendance a owl:ObjectProperty ;
    rdfs:domain ph:Tour ;
    rdfs:range ph:Attendance ;
    rdfs:label "has attendance"@en , "tem presença"@pt .

ph:documentedBy a owl:ObjectProperty ;
    rdfs:domain ph:Tour ;
    rdfs:label "documented by"@en , "documentado por"@pt ;
    rdfs:comment "Links a tour to media or social posts that document it."@en .

# ─── Route relations ─────────────────────────────────────────────────────

ph:executionOf a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain ph:ActualRoute ;
    rdfs:range ph:PlannedRoute ;
    rdfs:label "execution of"@en , "execução de"@pt ;
    rdfs:comment "Links an actual (recorded) route to the planned route it realises."@en .

ph:hasMetrics a owl:ObjectProperty ;
    rdfs:domain ph:Route ;
    rdfs:range ph:RideMetrics ;
    rdfs:label "has metrics"@en , "tem métricas"@pt .

# ─── Media relations ─────────────────────────────────────────────────────

ph:capturedAt a owl:ObjectProperty ;
    rdfs:domain ph:Media ;
    rdfs:range schema:GeoCoordinates ;
    rdfs:label "captured at"@en , "capturada em"@pt ;
    rdfs:comment "The geographic point where the media was captured (the geotag). Media with this property is 'georeferenced media'."@en .

ph:capturedDuring a owl:ObjectProperty ;
    rdfs:domain ph:Media ;
    rdfs:range ph:Tour ;
    rdfs:label "captured during"@en , "capturada durante"@pt .

# ─── Derivation (PROV) ───────────────────────────────────────────────────

ph:derivedFromNarrative a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    rdfs:domain ph:InstagramPost ;
    rdfs:range ph:TourNarrative ;
    rdfs:label "derived from narrative"@en , "derivado da narrativa"@pt ;
    rdfs:comment "The narrative is authored first; the post is published from it."@en .

ph:derivedFromMedia a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    rdfs:domain ph:InstagramStory ;
    rdfs:range ph:Media ;
    rdfs:label "derived from media"@en , "derivado da mídia"@pt .

# ─── Attendance relations ────────────────────────────────────────────────

ph:attendee a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain ph:Attendance ;
    rdfs:range ph:Person ;
    rdfs:label "attendee"@en , "participante"@pt .

ph:atTour a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain ph:Attendance ;
    rdfs:range ph:Tour ;
    rdfs:label "at tour"@en , "no pedal"@pt .

ph:role a owl:ObjectProperty ;
    rdfs:domain ph:Attendance ;
    rdfs:range ph:AttendanceRole ;
    rdfs:label "role"@en , "papel"@pt .

# ─── Numbering ───────────────────────────────────────────────────────────

ph:hasSeriesEntry a owl:ObjectProperty ;
    rdfs:domain ph:Tour ;
    rdfs:range ph:SeriesEntry ;
    rdfs:label "has series entry"@en , "tem entrada de série"@pt ;
    rdfs:comment "A tour may have several — one per numbering series it appears in."@en .

ph:inSeries a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain ph:SeriesEntry ;
    rdfs:range ph:Series ;
    rdfs:label "in series"@en , "na série"@pt .

# ═════════════════════════════════════════════════════════════════════════
# DATATYPE PROPERTIES
# ═════════════════════════════════════════════════════════════════════════

ph:editionNumber a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain ph:SeriesEntry ;
    rdfs:range xsd:integer ;
    rdfs:label "edition number"@en , "número da edição"@pt ;
    rdfs:comment "The number a tour holds within one series, e.g. 97."@en .

ph:rideCode a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain ph:Tour ;
    rdfs:range xsd:string ;
    rdfs:label "ride code"@en , "código do pedal"@pt ;
    rdfs:comment "Human-readable identifier combining series and edition, e.g. 'eH 97'."@en .

ph:displayPrecedence a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain ph:Series ;
    rdfs:range xsd:integer ;
    rdfs:label "display precedence"@en , "precedência de exibição"@pt ;
    rdfs:comment "Lower number = preferred when choosing which series code to show as a tour's label. The app prefers PH, then eH, then BT, BP, S."@en .

ph:instagramHandle a owl:DatatypeProperty ;
    rdfs:domain ph:Person ;
    rdfs:range xsd:string ;
    rdfs:label "Instagram handle"@en , "perfil no Instagram"@pt ;
    rdfs:comment "Instagram username without the leading '@', e.g. 'dandanlessa'."@en .

ph:gatheringTime a owl:DatatypeProperty ;
    rdfs:domain ph:Gathering ;
    rdfs:range xsd:dateTime ;
    rdfs:label "gathering time"@en , "horário de encontro"@pt ;
    rdfs:comment "When participants should arrive — the schema:doorTime analogue."@en .

# ─── Map layer configuration ─────────────────────────────────────────────

ph:tileUrlTemplate a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain ph:MapLayer ;
    rdfs:range xsd:string ;
    rdfs:label "tile URL template"@en , "modelo de URL dos tiles"@pt ;
    rdfs:comment "XYZ tile template with {z}/{x}/{y} placeholders. Used by tiled (non-WMS) layers."@en .

ph:wmsEndpoint a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain ph:MapLayer ;
    rdfs:range xsd:anyURI ;
    rdfs:label "WMS endpoint"@en , "endpoint WMS"@pt ;
    rdfs:comment "Base URL of the WMS service. Used by WMS layers in place of ph:tileUrlTemplate."@en .

ph:wmsLayerName a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain ph:MapLayer ;
    rdfs:range xsd:string ;
    rdfs:label "WMS layer name"@en , "nome da camada WMS"@pt ;
    rdfs:comment "The layer identifier requested from the WMS service, e.g. 'SaraBrasil_1930'."@en .

ph:maxZoom a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain ph:MapLayer ;
    rdfs:range xsd:integer ;
    rdfs:label "maximum zoom"@en , "zoom máximo"@pt ;
    rdfs:comment "Deepest zoom level the layer serves tiles for."@en .

ph:defaultOpacity a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain ph:MapLayer ;
    rdfs:range xsd:decimal ;
    rdfs:label "default opacity"@en , "opacidade padrão"@pt ;
    rdfs:comment "Opacity the layer loads with, from 0 (transparent) to 1 (opaque)."@en .

ph:enabledByDefault a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain ph:MapLayer ;
    rdfs:range xsd:boolean ;
    rdfs:label "enabled by default"@en , "ativa por padrão"@pt ;
    rdfs:comment "Whether the layer is on when the app first loads — the selected basemap, or a visible overlay."@en .

# ─── RideMetrics quantities (QUDT pattern) ───────────────────────────────
# Each ranges qudt:Quantity; a quantity carries qudt:numericValue + qudt:unit.

ph:distance a owl:ObjectProperty ;
    rdfs:domain ph:RideMetrics ;
    rdfs:range qudt:Quantity ;
    rdfs:label "distance"@en , "distância"@pt .

ph:totalAscent a owl:ObjectProperty ;
    rdfs:domain ph:RideMetrics ;
    rdfs:range qudt:Quantity ;
    rdfs:label "total ascent"@en , "ganho de elevação"@pt .

ph:totalDescent a owl:ObjectProperty ;
    rdfs:domain ph:RideMetrics ;
    rdfs:range qudt:Quantity ;
    rdfs:label "total descent"@en , "perda de elevação"@pt .

ph:energyExpenditure a owl:ObjectProperty ;
    rdfs:domain ph:RideMetrics ;
    rdfs:range qudt:Quantity ;
    rdfs:label "energy expenditure"@en , "energia gasta"@pt ;
    rdfs:comment "Estimated mechanical energy, typically in kilojoules."@en .

ph:movingDuration a owl:ObjectProperty ;
    rdfs:domain ph:RideMetrics ;
    rdfs:range qudt:Quantity ;
    rdfs:label "moving duration"@en , "duração em movimento"@pt .

# ═════════════════════════════════════════════════════════════════════════
# INDIVIDUALS — Attendance roles
# ═════════════════════════════════════════════════════════════════════════

ph:role-Rider a ph:AttendanceRole ;
    skos:prefLabel "Rider"@en , "Ciclista"@pt ;
    rdfs:comment "An ordinary participant."@en .

ph:role-RideLeader a ph:AttendanceRole ;
    skos:prefLabel "Ride leader"@en , "Puxador"@pt ;
    rdfs:comment "Leads the group and sets the pace at the front."@en .

ph:role-Sweep a ph:AttendanceRole ;
    skos:prefLabel "Sweep"@en , "Vassoura"@pt ;
    rdfs:comment "Rides at the back so that no participant is left behind."@en .

ph:role-Organizer a ph:AttendanceRole ;
    skos:prefLabel "Organizer"@en , "Organizador"@pt ;
    rdfs:comment "Planned the tour or handled logistics."@en .

# ═════════════════════════════════════════════════════════════════════════
# INDIVIDUALS — Numbering series
# ═════════════════════════════════════════════════════════════════════════
# Cada série é um esquema de numeração. Pedal Hidrográfico e grupos vizinhos
# numeram seus pedais em paralelo; uma tour pode ter número em várias delas.

ph:series-PH a ph:Series ;
    skos:notation "PH" ;
    skos:prefLabel "PH"@pt ;
    rdfs:comment "Pedais Hidrográficos regulares — os pedais canônicos do coletivo, originados em São Paulo."@pt ;
    ph:displayPrecedence 1 .

ph:series-eH a ph:Series ;
    skos:notation "eH" ;
    skos:prefLabel "eH"@pt ;
    rdfs:comment "Numeração universal — toda tour recebe um eH, de qualquer grupo. É o identificador presente na planilha Censo Hidrográfico."@pt ;
    ph:displayPrecedence 2 .

ph:series-BT a ph:Series ;
    skos:notation "BT" ;
    skos:prefLabel "BT"@pt ;
    rdfs:comment "Pedais ligados à Bicicletografia — outro coletivo."@pt ;
    ph:displayPrecedence 3 .

ph:series-BP a ph:Series ;
    skos:notation "BP" ;
    skos:prefLabel "BP"@pt ;
    rdfs:comment "Pedais ligados ao Bicipassarinhar — coletivo derivado do Pedal Hidrográfico."@pt ;
    ph:displayPrecedence 4 .

ph:series-S a ph:Series ;
    skos:notation "S" ;
    skos:prefLabel "S"@pt ;
    rdfs:comment "Pedal Hidrográfico Suado — pedais PH não-canônicos, de maior exigência energética."@pt ;
    ph:displayPrecedence 5 .

# ═════════════════════════════════════════════════════════════════════════
# INDIVIDUALS — Map layers
# ═════════════════════════════════════════════════════════════════════════
# As camadas cartográficas que o app desenha sob as rotas e as fotos. A
# configuração-fonte vive em public/app.js (BASE_LAYERS / OVERLAY_LAYERS);
# aqui ela fica descrita de forma independente da implementação.

ph:layer-osm a ph:BasemapLayer ;
    rdfs:label "OpenStreetMap"@en , "OpenStreetMap"@pt ;
    ph:tileUrlTemplate "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png" ;
    ph:maxZoom 19 ;
    ph:defaultOpacity 1.0 ;
    ph:enabledByDefault true ;
    dcterms:rights "© OpenStreetMap contributors" .

ph:layer-satellite a ph:BasemapLayer ;
    rdfs:label "Satellite"@en , "Satélite"@pt ;
    rdfs:comment "Esri World Imagery — note the {z}/{y}/{x} tile order."@en ;
    ph:tileUrlTemplate "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}" ;
    ph:maxZoom 19 ;
    ph:defaultOpacity 1.0 ;
    ph:enabledByDefault false ;
    dcterms:rights "Imagery © Esri, Maxar, Earthstar Geographics, and the GIS User Community" .

ph:layer-rmsampa a ph:OverlayLayer ;
    rdfs:label "Colour topography"@en , "Topografia colorida"@pt ;
    rdfs:comment "Pedal Hidrográfico's own shaded-relief topographic tiles for the São Paulo metropolitan region."@en ;
    ph:tileUrlTemplate "https://telhas.pedalhidrografi.co/rmsampa-v2/{z}/{x}/{y}.png" ;
    ph:maxZoom 19 ;
    ph:defaultOpacity 0.85 ;
    ph:enabledByDefault true ;
    dcterms:publisher "Pedal Hidrográfico" ;
    dcterms:rights "Topografia: Pedal Hidrográfico" .

ph:layer-sara1930 a ph:OverlayLayer ;
    rdfs:label "SARA Brasil 1930"@en , "SARA Brasil 1930"@pt ;
    rdfs:comment "Historical 1930 aerial-photo mosaic of São Paulo, served from GeoSampa's GeoServer over WMS."@en ;
    ph:wmsEndpoint "https://raster.geosampa.prefeitura.sp.gov.br/geoserver/geoportal/wms"^^xsd:anyURI ;
    ph:wmsLayerName "SaraBrasil_1930" ;
    ph:maxZoom 19 ;
    ph:defaultOpacity 0.85 ;
    ph:enabledByDefault false ;
    dcterms:rights "SARA Brasil 1930 · GeoSampa / Prefeitura de São Paulo" .
